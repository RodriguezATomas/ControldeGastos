# Archivo de configuración de variables de entorno, aquí se definen las variables necesarias para configurar el servidor, la conexión a la base de datos y las opciones de autenticación
PORT=3000
MONGO_URI=mongodb://localhost:27017/control_gastos
JWT_ACCESS_SECRET=access_secret
JWT_REFRESH_SECRET=refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
